    "uninstaller": {
        "script": [
            "$uninstaller = Get-ChildItem \"$env:LOCALAPPDATA\\Programs\\Deezer\" -Filter 'Uninstall*.exe' -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($uninstaller) { Start-Process -Wait $uninstaller.FullName -ArgumentList '/S' }"
        ]
    },
    "checkver": {
        "url": "https://www.filehorse.com/download-deezer-desktop/",
        "regex": "Deezer Desktop ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_$version.exe"
            }
        }
    }
