{
    "version": "7.1.130",
    "description": "Official Deezer music streaming desktop application",
    "homepage": "https://www.deezer.com",
    "license": "Freeware",
    "architecture": {
        "32bit": {
            "url": "https://cdn-content.dzcdn.net/builds/deezer-desktop/8cF2rAuKxLcU1oMDmCYm8Uiqe19Ql0HTySLssdzLkQ9ZWHuDTp2JBtQOvdrFzWPA/win32/x86/7.1.130/DeezerDesktopSetup_7.1.130.exe",
            "hash": "2B1188C57322CAB60C1608E7CC08AE4E2833C7C4C40ADF5F048B2C045D50F454"
        },
        "64bit": {
            "url": "https://cdn-content.dzcdn.net/builds/deezer-desktop/8cF2rAuKxLcU1oMDmCYm8Uiqe19Ql0HTySLssdzLkQ9ZWHuDTp2JBtQOvdrFzWPA/win32/x86/7.1.130/DeezerDesktopSetup_7.1.130.exe",
            "hash": "2B1188C57322CAB60C1608E7CC08AE4E2833C7C4C40ADF5F048B2C045D50F454"
        }
    },
    "installer": {
        "script": [
            "Start-Process -Wait \"$dir\\DeezerDesktopSetup_$version.exe\" -ArgumentList '/S'"
        ]
    },
    "post_install": [
        "$deezerExe = Join-Path $env:LOCALAPPDATA 'Programs\\Deezer\\Deezer.exe'",
        "if (Test-Path $deezerExe) {",
        "    $sm = if ($global) { 'CommonStartMenu' } else { 'StartMenu' }",
        "    $folder = Join-Path ([Environment]::GetFolderPath($sm)) 'Programs\\Scoop Apps'",
        "    New-Item -ItemType Directory -Force -Path $folder | Out-Null",
        "    $ws = New-Object -ComObject WScript.Shell",
        "    $sc = $ws.CreateShortcut((Join-Path $folder 'Deezer.lnk'))",
        "    $sc.TargetPath = $deezerExe",
        "    $sc.WorkingDirectory = (Split-Path $deezerExe -Parent)",
        "    $sc.Save()",
        "    Write-Host 'Created Start Menu shortcut for Deezer'",
        "} else {",
        "    Write-Host \"Deezer.exe not found at $deezerExe - shortcut skipped\" -ForegroundColor Yellow",
        "}"
    ],
    "pre_uninstall": [
        "$sm = if ($global) { 'CommonStartMenu' } else { 'StartMenu' }",
        "$lnk = Join-Path ([Environment]::GetFolderPath($sm)) 'Programs\\Scoop Apps\\Deezer.lnk'",
        "if (Test-Path $lnk) { Remove-Item $lnk -ErrorAction SilentlyContinue }"
    ],
    "uninstaller": {
        "script": [
            "$dz = Join-Path $env:LOCALAPPDATA 'Programs\\Deezer'",
            "if (Test-Path -LiteralPath $dz) {",
            "    $u = Get-ChildItem -LiteralPath $dz -Filter 'Uninstall*.exe' -ErrorAction SilentlyContinue | Select-Object -First 1",
            "    if (!$u) { $u = Get-ChildItem -LiteralPath $dz -Filter 'unins*.exe' -ErrorAction SilentlyContinue | Select-Object -First 1 }",
            "    if ($u) { Start-Process -Wait $u.FullName -ArgumentList '/S' }",
            "    else { Write-Host 'No Deezer uninstaller exe in' $dz -ForegroundColor Yellow }",
            "}"
        ]
    },
    "checkver": {
        "url": "https://www.filehorse.com/download-deezer-desktop/",
        "regex": "Deezer Desktop ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_$version.exe"
            },
            "64bit": {
                "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_$version.exe"
            }
        }
    }
}
