{
    "version": "7.1.150",
    "description": "Official Deezer music streaming desktop application",
    "homepage": "https://www.deezer.com",
    "license": "Freeware",
    "architecture": {
        "32bit": {
            "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_7.1.150.exe",
            "hash": "353e148143485eddcfc39e0650c02214d3bcd16a6abd018be61cd7b50a779228"
        },
        "64bit": {
            "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_7.1.150.exe",
            "hash": "353e148143485eddcfc39e0650c02214d3bcd16a6abd018be61cd7b50a779228"
        }
    },
    "installer": {
        "script": "Start-Process -Wait \"$dir\\DeezerDesktopSetup_$version.exe\" -ArgumentList '/S'"
    },
    "post_install": [
        "$sm = if ($global) { 'CommonStartMenu' } else { 'StartMenu' }",
        "$scoopLnkFolder = Join-Path ([Environment]::GetFolderPath($sm)) 'Programs\\Scoop Apps'",
        "New-Item -ItemType Directory -Force -Path $scoopLnkFolder | Out-Null",
        "$destLnk = Join-Path $scoopLnkFolder 'Deezer.lnk'",
        "$roamPrograms = Join-Path $env:APPDATA 'Microsoft\\Windows\\Start Menu\\Programs'",
        "$srcLnk = Join-Path $roamPrograms 'Deezer.lnk'",
        "if (!(Test-Path -LiteralPath $srcLnk)) { $srcLnk = Join-Path $roamPrograms 'Deezer\\Deezer.lnk' }",
        "if (Test-Path -LiteralPath $srcLnk) {",
        "    Move-Item -LiteralPath $srcLnk -Destination $destLnk -Force",
        "    Write-Host 'Moved Deezer Start Menu shortcut to Scoop Apps'",
        "} else {",
        "    $deezerExe = Join-Path $env:LOCALAPPDATA 'Programs\\deezer-desktop\\Deezer.exe'",
        "    if (Test-Path -LiteralPath $deezerExe) {",
        "        $ws = New-Object -ComObject WScript.Shell",
        "        $sc = $ws.CreateShortcut($destLnk)",
        "        $sc.TargetPath = $deezerExe",
        "        $sc.WorkingDirectory = (Split-Path $deezerExe -Parent)",
        "        $sc.Save()",
        "        Write-Host 'Created Scoop Apps shortcut (installer left no Start Menu link)'",
        "    } else { Write-Host 'Deezer shortcut and exe not found - check install' -ForegroundColor Yellow }",
        "}"
    ],
    "pre_uninstall": [
        "$sm = if ($global) { 'CommonStartMenu' } else { 'StartMenu' }",
        "$roamPrograms = Join-Path $env:APPDATA 'Microsoft\\Windows\\Start Menu\\Programs'",
        "$candidates = @(",
        "    (Join-Path ([Environment]::GetFolderPath($sm)) 'Programs\\Scoop Apps\\Deezer.lnk'),",
        "    (Join-Path $roamPrograms 'Deezer.lnk'),",
        "    (Join-Path $roamPrograms 'Deezer\\Deezer.lnk')",
        ")",
        "foreach ($p in $candidates) { if ($p -and (Test-Path -LiteralPath $p)) { Remove-Item -LiteralPath $p -Force -ErrorAction SilentlyContinue } }"
    ],
    "uninstaller": {
        "script": [
            "$u = Join-Path $env:LOCALAPPDATA 'Programs\\deezer-desktop\\Uninstall Deezer.exe'",
            "if (Test-Path -LiteralPath $u) { Start-Process -Wait -FilePath $u -ArgumentList '/S' }",
            "else { Write-Host 'Uninstaller not found:' $u -ForegroundColor Yellow }"
        ]
    },
    "checkver": {
        "url": "https://www.filehorse.com/download-deezer-desktop/",
        "regex": "Deezer Desktop ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_$version.exe"
            },
            "64bit": {
                "url": "https://www.deezer.com/desktop/download?platform=win32&architecture=x86#/DeezerDesktopSetup_$version.exe"
            }
        }
    }
}
